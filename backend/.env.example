# MongoDB - IMPORTANT: USE_MEMORY_DB=false pour sauvegarder les données
USE_MEMORY_DB=false
# Atlas (cloud) OU local:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/dating-app

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=votre_client_id_google.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre_client_secret_google
GOOGLE_PROJECT_ID=votre_project_id
GOOGLE_REDIRECT_URI=https://auth.expo.io/@votre_username/votre-app


# JWT
JWT_SECRET=votre_secret_jwt_tres_long_et_securise
JWT_EXPIRES=7d

# Frontend (CORS, emails) - Ajouter URL Vercel en production
FRONTEND_URL=http://localhost:5173
# Exemple production multi-origines:
# FRONTEND_URL=https://votre-app.vercel.app,https://votre-autre-domaine.vercel.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optionnel - Nodemailer)
# Si SMTP n'est pas configure en developpement, un code de reset sera retourne par l'API et logue en console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="MeetUp <noreply@meetup.app>"

# Server
PORT=5000
RATE_LIMIT_MAX=1200

# Production Socket.IO
NODE_ENV=development

