{
  "project": {
    "name": "MeetUp - Dating App",
    "version": "1.0.0",
    "description": "Modern full-stack dating application",
    "repository": "https://github.com/your-username/site"
  },
  "deployment": {
    "frontend": {
      "platform": "Vercel",
      "framework": "Vite",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "rootDirectory": "frontend",
      "environmentVariables": {
        "VITE_API_URL": "https://backend-url.onrender.com/api",
        "VITE_SOCKET_URL": "https://backend-url.onrender.com",
        "VITE_GOOGLE_CLIENT_ID": ""
      }
    },
    "backend": {
      "platform": "Render",
      "runtime": "Node",
      "buildCommand": "npm install",
      "startCommand": "npm start",
      "rootDirectory": "backend",
      "environmentVariables": {
        "NODE_ENV": "production",
        "PORT": "5000",
        "MONGODB_URI": "mongodb+srv://...",
        "JWT_SECRET": "generate-a-strong-secret",
        "FRONTEND_URL": "https://your-app.vercel.app",
        "GOOGLE_CLIENT_ID": "",
        "CLOUDINARY_CLOUD_NAME": "",
        "CLOUDINARY_API_KEY": "",
        "CLOUDINARY_API_SECRET": "",
        "SMTP_HOST": "smtp.gmail.com",
        "SMTP_PORT": "587",
        "SMTP_USER": "",
        "SMTP_PASS": "",
        "EMAIL_FROM": "MeetUp <noreply@meetup.app>"
      }
    },
    "database": {
      "type": "MongoDB",
      "provider": "MongoDB Atlas",
      "url": "https://mongodb.com/cloud/atlas",
      "tier": "M0 (free)"
    }
  },
  "services": {
    "mongodb_atlas": {
      "name": "MongoDB Atlas",
      "url": "https://mongodb.com/cloud/atlas",
      "setup_time": "2 minutes",
      "cost": "free tier available"
    },
    "google_oauth": {
      "name": "Google Cloud Console",
      "url": "https://console.cloud.google.com",
      "setup_time": "5 minutes",
      "cost": "free",
      "optional": true
    },
    "cloudinary": {
      "name": "Cloudinary",
      "url": "https://cloudinary.com",
      "setup_time": "3 minutes",
      "cost": "free tier available",
      "optional": true
    }
  },
  "documentation": {
    "quick_start": {
      "file": "QUICK_DEPLOY.md",
      "time": "5 minutes",
      "description": "Deploy in 5 minutes"
    },
    "full_guide": {
